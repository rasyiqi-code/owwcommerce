{
    "name": "owwcommerce/owwcommerce",
    "description": "Zero-bloatware E-Commerce Engine for WordPress",
    "type": "wordpress-plugin",
    "require": {
        "php": ">=8.1",
        "phpoffice/phpspreadsheet": "^5.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "yoast/phpunit-polyfills": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "OwwCommerce\\": "includes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OwwCommerce\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
